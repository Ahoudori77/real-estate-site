---
import type { PropertyListItem } from "../../types/property";
import {
  formatAddress,
  formatArea,
  formatJapaneseDate,
  formatPriceToManYen,
  formatPropertyTypeLabel,
} from "../../lib/utils/format";

interface Props {
  property: PropertyListItem;
}

const { property } = Astro.props;
const safeFeatures = property.features ?? [];
---

<article class="property-card">
  <a href={`/properties/${property.slug}`} class="image-link">
    {property.thumbnailUrl ? (
      <img
        src={property.thumbnailUrl}
        alt={property.title}
        class="thumbnail"
        loading="lazy"
      />
    ) : (
      <div class="thumbnail placeholder">No Image</div>
    )}
  </a>

  <div class="content">
    <div class="top-row">
      <span class="type-badge">{formatPropertyTypeLabel(property.type)}</span>
      <span class="updated-at">更新日: {formatJapaneseDate(property.updatedAt)}</span>
    </div>

    <h3 class="title">
      <a href={`/properties/${property.slug}`}>{property.title}</a>
    </h3>

    <p class="price">{formatPriceToManYen(property.price)}</p>

    <dl class="meta-list">
      <div>
        <dt>所在地</dt>
        <dd>
          {formatAddress({
            prefecture: property.prefecture,
            city: property.city,
            address1: property.address1,
          })}
        </dd>
      </div>

      {(property.nearestStation || property.accessNote) && (
        <div>
          <dt>交通</dt>
          <dd>{[property.nearestStation, property.accessNote].filter(Boolean).join(" / ")}</dd>
        </div>
      )}

      <div>
        <dt>土地面積</dt>
        <dd>{formatArea(property.landAreaSqm)}</dd>
      </div>

      {property.type === "house" && (
        <>
          <div>
            <dt>建物面積</dt>
            <dd>{formatArea(property.buildingAreaSqm)}</dd>
          </div>
          <div>
            <dt>間取り</dt>
            <dd>{property.floorPlan ?? "-"}</dd>
          </div>
        </>
      )}
    </dl>

    {safeFeatures.length > 0 && (
      <ul class="feature-list">
        {safeFeatures.slice(0, 3).map((feature) => (
          <li>{feature}</li>
        ))}
      </ul>
    )}

    <div class="actions">
      <a href={`/properties/${property.slug}`} class="detail-link">詳細を見る</a>
    </div>
  </div>
</article>
<style>
  .property-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 20px;
    background: #fff;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .property-card:hover {
    transform: translateY(-2px);
    border-color: rgba(231, 52, 24, 0.28);
    box-shadow: 0 22px 48px rgba(46, 10, 5, 0.12);
  }

  .image-link {
    display: block;
    background: #f3f4f6;
  }

  .thumbnail {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 240px;
    object-fit: cover;
  }

  .placeholder {
    display: grid;
    place-items: center;
    color: var(--color-muted);
    font-weight: 800;
  }

  .content {
    display: grid;
    gap: 14px;
    padding: 22px 24px 22px 0;
  }

  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .type-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 30px;
    padding: 0 13px;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    font-size: 13px;
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 8px 18px rgba(231, 52, 24, 0.14);
  }

  .updated-at {
    color: var(--color-muted);
    font-size: 13px;
    font-weight: 700;
  }

  .title {
    margin: 0;
    color: var(--color-text);
    font-size: 24px;
    line-height: 1.4;
    font-weight: 900;
  }

  .title a {
    color: inherit;
    text-decoration: none;
  }

  .title a:hover {
    color: var(--color-accent-dark);
  }

  .price {
    margin: 0;
    color: var(--color-accent-dark);
    font-size: 22px;
    line-height: 1.3;
    font-weight: 900;
  }

  .meta-list {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .meta-list div {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
  }

  .meta-list dt {
    color: var(--color-muted);
    font-weight: 800;
  }

  .meta-list dd {
    margin: 0;
    color: var(--color-text);
    font-weight: 700;
  }

  .feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .feature-list li {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--color-accent-pale);
    color: var(--color-accent-dark);
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
  }

  .actions {
    margin-top: 4px;
  }

  .detail-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 38px;
    padding: 0 16px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-strong) 100%
    );
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 22px rgba(231, 52, 24, 0.18);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
  }

  .detail-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 26px rgba(231, 52, 24, 0.24);
    opacity: 0.98;
  }

  @media (max-width: 900px) {
    .property-card {
      grid-template-columns: 1fr;
    }

    .content {
      padding: 0 18px 18px;
    }

    .thumbnail {
      min-height: 220px;
    }

    .title {
      font-size: 20px;
    }

    .price {
      font-size: 24px;
    }

    .meta-list div {
      grid-template-columns: 80px 1fr;
    }
  }
</style>