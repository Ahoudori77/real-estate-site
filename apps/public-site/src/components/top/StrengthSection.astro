---
const mainImage = {
  // 画像が決まったらここを差し替え
  // 例: "/images/sections/strength-main.jpg"
  src: "/images/sections/hero-placeholder.jpg",
  alt: "京都北部・周辺エリアの住まい探しをサポートする不動産会社のイメージ",
};

const strengths = [
  {
    label: "LOCAL",
    title: "地域に寄り添うご提案",
    text: "京都北部・周辺エリアの暮らしや土地の特徴をふまえ、住まい探しを丁寧にお手伝いします。",
  },
  {
    label: "SALES",
    title: "土地・戸建ての売買に対応",
    text: "土地や戸建てを中心に、購入前の不安や条件整理、現地確認までわかりやすくサポートします。",
  },
  {
    label: "SUPPORT",
    title: "相談しやすい進め方",
    text: "ご相談から物件紹介、ご契約まで、無理なく進められるよう一つひとつ確認しながら伴走します。",
  },
];
---

<section class="strength-section section section--plain">
  <div class="container">
    <div class="strength-layout">
      <div class="strength-visual">
        {
          mainImage.src ? (
            <img src={mainImage.src} alt={mainImage.alt} loading="lazy" />
          ) : (
            <div class="strength-visual__placeholder" aria-label="画像選定中の仮エリア">
              <span>IMAGE</span>
              <p>地域の風景・住まい・相談風景などの画像を差し込めます</p>
            </div>
          )
        }

        <div class="strength-visual__badge">
          <span>REAL ESTATE SUPPORT</span>
          <strong>土地・戸建てのご相談を丁寧に</strong>
        </div>
      </div>

      <div class="strength-content">
        <div class="strength-section__header">
          <h2>選ばれる理由</h2>
          <p>
            地域の暮らしに目を向けながら、土地・戸建ての売買を丁寧にサポートします。
          </p>
        </div>

        <div class="strength-list">
          {strengths.map((item, index) => (
            <article class="strength-item">
              <div class="strength-item__number">
                {String(index + 1).padStart(2, "0")}
              </div>

              <div class="strength-item__body">
                <p class="strength-item__label">{item.label}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .strength-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 56px;
    align-items: center;
  }

  .strength-visual {
    position: relative;
    min-height: 520px;
    border-radius: 32px;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(255, 248, 244, 0.95), rgba(255, 255, 255, 0.88)),
      #f5eee9;
    border: 1px solid rgba(234, 219, 210, 0.9);
    box-shadow: 0 24px 60px rgba(92, 48, 32, 0.12);
  }

  .strength-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(47, 39, 36, 0.02) 0%, rgba(47, 39, 36, 0.28) 100%);
    pointer-events: none;
  }

  .strength-visual img {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
    display: block;
  }

  .strength-visual__placeholder {
    min-height: 520px;
    display: grid;
    place-content: center;
    gap: 14px;
    padding: 40px;
    text-align: center;
    color: #8a756a;
  }

  .strength-visual__placeholder span {
    color: rgba(233, 71, 46, 0.32);
    font-size: 52px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .strength-visual__placeholder p {
    margin: 0;
    font-weight: 700;
    line-height: 1.8;
  }

  .strength-visual__badge {
    position: absolute;
    left: 28px;
    right: 28px;
    bottom: 28px;
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.56);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    padding: 22px 24px;
    box-shadow: 0 16px 36px rgba(47, 39, 36, 0.14);
    backdrop-filter: blur(10px);
  }

  .strength-visual__badge span {
    display: block;
    margin-bottom: 8px;
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .strength-visual__badge strong {
    display: block;
    color: var(--color-text);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.45;
    font-weight: 900;
  }

  .strength-content {
    min-width: 0;
  }

  .strength-section__header {
    margin-bottom: 34px;
  }

  .strength-section__header h2 {
    margin: 0 0 14px;
    color: var(--color-text);
    font-size: clamp(32px, 3.4vw, 46px);
    line-height: 1.22;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .strength-section__header p {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.9;
  }

  .strength-list {
    display: grid;
    gap: 18px;
  }

  .strength-item {
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr);
    gap: 22px;
    align-items: start;
    border: 1px solid rgba(234, 219, 210, 0.92);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.9);
    padding: 24px 26px;
    box-shadow: 0 14px 32px rgba(92, 48, 32, 0.07);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .strength-item:hover {
    transform: translateY(-2px);
    border-color: rgba(233, 71, 46, 0.28);
    box-shadow: 0 18px 40px rgba(92, 48, 32, 0.11);
  }

  .strength-item__number {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 18px;
    background: rgba(233, 71, 46, 0.09);
    color: var(--color-accent);
    font-size: 20px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .strength-item__label {
    margin: 0 0 8px;
    color: #8a756a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .strength-item h3 {
    margin: 0 0 10px;
    color: var(--color-text);
    font-size: clamp(21px, 2vw, 27px);
    line-height: 1.35;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .strength-item__body p:last-child {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.9;
  }

  @media (max-width: 980px) {
    .strength-layout {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .strength-visual,
    .strength-visual img,
    .strength-visual__placeholder {
      min-height: 380px;
    }
  }

  @media (max-width: 640px) {
    .strength-section__header {
      margin-bottom: 26px;
    }

    .strength-section__header h2 {
      font-size: clamp(28px, 8vw, 38px);
    }

    .strength-visual {
      border-radius: 24px;
    }

    .strength-visual,
    .strength-visual img,
    .strength-visual__placeholder {
      min-height: 320px;
    }

    .strength-visual__placeholder {
      padding: 28px;
    }

    .strength-visual__placeholder span {
      font-size: 38px;
    }

    .strength-visual__badge {
      left: 18px;
      right: 18px;
      bottom: 18px;
      border-radius: 18px;
      padding: 18px;
    }

    .strength-item {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 22px;
      border-radius: 20px;
    }

    .strength-item__number {
      width: 52px;
      height: 52px;
      border-radius: 16px;
    }
  }
</style>