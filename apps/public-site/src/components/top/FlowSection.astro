---
const icons = {
  consultation: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M5 5h14v9H8.8L5 17.5V5Z" />
      <path d="M8 8h8" />
      <path d="M8 11h5" />
    </svg>
  `,
  property: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 11.5 12 5l8 6.5" />
      <path d="M6.5 10.5V19h11v-8.5" />
      <path d="M10 19v-5h4v5" />
    </svg>
  `,
  location: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 21s6-5.2 6-11a6 6 0 0 0-12 0c0 5.8 6 11 6 11Z" />
      <path d="M12 12.2a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4Z" />
    </svg>
  `,
  contract: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M7 3.8h8.5L19 7.3V20H7V3.8Z" />
      <path d="M15.5 3.8v3.5H19" />
      <path d="M9.5 11h7" />
      <path d="M9.5 14h7" />
      <path d="M9.5 17h4" />
      <path d="M5 7v13h10" />
    </svg>
  `,
};

const steps = [
  {
    title: "ご相談",
    label: "CONSULTATION",
    icon: "consultation",
    text: "エリアやご予算、土地・戸建てに関するご希望条件をお伺いします。",
    image: "",
    imageAlt: "",
  },
  {
    title: "物件紹介",
    label: "PROPERTY",
    icon: "property",
    text: "ご希望に近い候補物件をご提案し、条件や特徴をわかりやすくご案内します。",
    image: "",
    imageAlt: "",
  },
  {
    title: "現地確認",
    label: "LOCATION",
    icon: "location",
    text: "物件だけでなく、周辺環境や暮らしの導線も含めて現地をご確認いただきます。",
    image: "",
    imageAlt: "",
  },
  {
    title: "ご契約",
    label: "CONTRACT",
    icon: "contract",
    text: "内容にご納得いただいたうえで、契約手続きを丁寧に進めます。",
    image: "",
    imageAlt: "",
  },
];
---

<section class="flow-section section section--warm">
  <div class="container">
    <div class="flow-panel">
      <div class="flow-panel__header">
        <h2>ご相談からご契約までの流れ</h2>
        <p>
          初めて不動産を購入される方にも、流れをひとつずつわかりやすくご案内します。
        </p>
      </div>

      <div class="flow-timeline" aria-label="ご相談からご契約までの流れ">
        {steps.map((item, index) => (
          <article class="flow-step-card">
            <div class="flow-step-card__inner">
              {item.image && (
                <div class="flow-step-card__image">
                  <img src={item.image} alt={item.imageAlt} loading="lazy" />
                </div>
              )}

              <div class="flow-step-card__content">
                <div class="flow-step-card__top">
                  <span class="flow-step-card__icon" set:html={icons[item.icon]}></span>
                  <span class="flow-step-card__number">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                </div>

                <p class="flow-step-card__label">{item.label}</p>

                <div class="flow-step-card__heading">
                  <h3>{item.title}</h3>
                </div>

                <div class="flow-step-card__body">
                  <p>{item.text}</p>
                </div>
              </div>
            </div>

            {index < steps.length - 1 && (
              <span class="flow-step-arrow" aria-hidden="true"></span>
            )}
          </article>
        ))}
      </div>

      <div class="flow-panel__footer">
        <div class="flow-footer-copy">
          <p class="flow-footer-title">物件探しの前段階でもご相談いただけます。</p>
          <p>条件整理やエリア選びから、お気軽にご相談ください。</p>
        </div>

        <a href="/contact" class="flow-contact-link">相談してみる</a>
      </div>
    </div>
  </div>
</section>

<style>
  .flow-panel {
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.96);
    padding: 44px;
    box-shadow: 0 26px 70px rgba(46, 10, 5, 0.22);
  }

  .flow-panel__header {
    max-width: 820px;
    margin: 0 auto 38px;
    text-align: center;
  }

  .flow-panel__header h2 {
    margin: 0 0 14px;
    color: var(--color-text);
    font-size: clamp(30px, 3.2vw, 44px);
    line-height: 1.22;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .flow-panel__header p {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.8;
  }

  .flow-timeline {
    display: grid;
    gap: 22px;
  }

  .flow-step-card {
    position: relative;
  }

  .flow-step-card__inner {
    position: relative;
    height: 100%;
    border: 1px solid rgba(234, 219, 210, 0.95);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 16px 36px rgba(92, 48, 32, 0.1);
    overflow: hidden;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .flow-step-card__inner::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 5px;
    background: linear-gradient(90deg, var(--color-accent) 0%, #ff8a72 100%);
    z-index: 1;
  }

  .flow-step-card:hover .flow-step-card__inner {
    transform: translateY(-3px);
    border-color: rgba(233, 71, 46, 0.3);
    box-shadow: 0 22px 46px rgba(92, 48, 32, 0.14);
  }

  .flow-step-card__image {
    position: relative;
    height: 130px;
    background: #f4eee9;
    overflow: hidden;
  }

  .flow-step-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .flow-step-card__content {
    padding: 26px 24px 26px;
  }

  .flow-step-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .flow-step-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 18px;
    background: rgba(233, 71, 46, 0.09);
    color: var(--color-accent);
  }

  .flow-step-card__icon :global(svg) {
    width: 28px;
    height: 28px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .flow-step-card__number {
    color: rgba(233, 71, 46, 0.16);
    font-size: 42px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -0.06em;
  }

  .flow-step-card__label {
    margin: 0 0 8px;
    color: #8a756a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .flow-step-card__heading {
    margin-bottom: 12px;
  }

  .flow-step-card__heading h3 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(24px, 2vw, 30px);
    line-height: 1.25;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .flow-step-card__body p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.95;
    font-weight: 700;
  }

  .flow-panel__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    margin-top: 30px;
    border: 1px solid rgba(234, 219, 210, 0.9);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(233, 71, 46, 0.1), transparent 34%),
      rgba(255, 255, 255, 0.86);
    padding: 22px 24px;
  }

  .flow-footer-copy {
    display: grid;
    gap: 6px;
  }

  .flow-footer-copy p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.8;
    font-weight: 700;
  }

  .flow-footer-title {
    color: var(--color-text) !important;
    font-size: 16px;
    font-weight: 900 !important;
  }

  .flow-contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    font-weight: 900;
    text-decoration: none;
    box-shadow: var(--shadow-accent);
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .flow-contact-link:hover {
    background: var(--color-accent-dark);
    transform: translateY(-1px);
    box-shadow: 0 14px 26px rgba(201, 54, 34, 0.22);
  }

  @media (min-width: 900px) {
    .flow-timeline {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .flow-step-arrow {
      position: absolute;
      top: 50%;
      right: -37px;
      width: 64px;
      height: 34px;
      transform: translateY(-50%);
      z-index: 6;
      pointer-events: none;
    }

    .flow-step-arrow::before,
    .flow-step-arrow::after {
      content: "";
      position: absolute;
      inset: 0;
      clip-path: polygon(0 24%, 64% 24%, 64% 0, 100% 50%, 64% 100%, 64% 76%, 0 76%);
    }

    .flow-step-arrow::before {
      inset: -1px;
      background: rgba(255, 255, 255, 0.92);
      filter: drop-shadow(0 6px 12px rgba(47, 39, 36, 0.12));
    }

    .flow-step-arrow::after {
      background: linear-gradient(180deg, #f05d3b 0%, #e9472e 100%);
    }
  }

  @media (max-width: 900px) {
    .flow-panel {
      padding: 28px;
      border-radius: 28px;
    }

    .flow-panel__footer {
      display: grid;
    }

    .flow-contact-link {
      width: fit-content;
    }

    .flow-step-arrow {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .flow-panel {
      padding: 20px;
      border-radius: 24px;
    }

    .flow-panel__header {
      margin-bottom: 24px;
    }

    .flow-panel__header h2 {
      font-size: clamp(28px, 8vw, 38px);
    }

    .flow-step-card__content {
      padding: 24px 18px 22px;
    }

    .flow-step-card__icon {
      width: 48px;
      height: 48px;
      border-radius: 16px;
    }

    .flow-step-card__number {
      font-size: 38px;
    }

    .flow-step-card__heading h3 {
      font-size: 24px;
    }

    .flow-panel__footer {
      padding: 18px;
      border-radius: 20px;
    }
  }
</style>