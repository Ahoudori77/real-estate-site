---
type InquiryType = "general" | "property" | "visit" | "document" | "other";

type Props = {
  inquiryType?: InquiryType;
  propertySlug?: string | null;
  title?: string;
  description?: string;
  submitLabel?: string;
};

const {
  inquiryType = "general",
  propertySlug = null,
  title = "お問い合わせ",
  description = "必要事項をご入力のうえ、送信してください。",
  submitLabel = "送信する",
} = Astro.props;

---

<section class="inquiry-box">
  <div class="inquiry-box__header">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <form
    class="inquiry-form"
    data-inquiry-form
    data-inquiry-type={inquiryType}
    data-property-slug={propertySlug ?? ""}
  >
    <div class="inquiry-form__grid">
      <label class="inquiry-form__field">
        <span>お名前<span class="required">必須</span></span>
        <input type="text" name="name" maxlength="50" required />
      </label>

      <label class="inquiry-form__field">
        <span>メールアドレス<span class="required">必須</span></span>
        <input type="email" name="email" maxlength="254" required />
      </label>

      <label class="inquiry-form__field">
        <span>電話番号</span>
        <input type="tel" name="phone" maxlength="20" />
      </label>
    </div>

    <label class="inquiry-form__field">
      <span>お問い合わせ内容<span class="required">必須</span></span>
      <textarea
      name="message"
      rows="6"
      minlength="10"
      maxlength="2000"
      required
    ></textarea>
    </label>

    <p class="inquiry-form__note">
      送信内容を確認のうえ、担当者より順次ご連絡いたします。
    </p>

    <div class="inquiry-form__actions">
      <button type="submit" data-submit-button>{submitLabel}</button>
      <p class="inquiry-form__message" data-form-message aria-live="polite"></p>
    </div>
  </form>
</section>

<style>
  .inquiry-box {
    margin-top: 48px;
    padding: 24px;
    border: 1px solid var(--color-border, #eadbd5);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(47, 39, 36, 0.06);
  }

  .inquiry-box__header {
    margin-bottom: 24px;
  }

  .inquiry-box__header h2 {
    margin: 0 0 8px;
    font-size: 1.5rem;
  }

  .inquiry-box__header p {
    margin: 0;
    color: var(--color-muted, #6b7280);
    line-height: 1.7;
  }

  .inquiry-form {
    display: grid;
    gap: 20px;
  }

  .inquiry-form__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .inquiry-form__field {
    display: grid;
    gap: 8px;
  }

  .inquiry-form__field span {
    font-weight: 700;
  }

  .inquiry-form__field input,
  .inquiry-form__field textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--color-border, #eadbd5);
    border-radius: 12px;
    font: inherit;
    box-sizing: border-box;
    background: #fff;
  }

  .inquiry-form__field input:focus,
  .inquiry-form__field textarea:focus {
    outline: 3px solid var(--color-accent-soft, #fff1ed);
    border-color: var(--color-accent, #ff6347);
  }

  .inquiry-form__field textarea {
    resize: vertical;
  }

  .required {
    margin-left: 8px;
    color: var(--color-accent-dark, #d94832);
    font-size: 0.85rem;
  }

  .inquiry-form__note {
    margin: 0;
    padding: 12px 14px;
    border-radius: 12px;
    background: var(--color-accent-soft, #fff1ed);
    color: var(--color-muted, #6b7280);
    font-size: 0.95rem;
  }

  .inquiry-form__actions {
    display: grid;
    gap: 12px;
    align-items: start;
  }

  .inquiry-form__actions button {
    width: fit-content;
    min-width: 180px;
    padding: 12px 20px;
    border: none;
    border-radius: 999px;
    background: var(--color-accent, #ff6347);
    color: #fff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(255, 99, 71, 0.18);
  }

  .inquiry-form__actions button:hover {
    background: var(--color-accent-dark, #d94832);
  }

  .inquiry-form__actions button[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .inquiry-form__message {
    margin: 0;
    min-height: 1.5em;
    color: #111827;
    line-height: 1.6;
  }

  .inquiry-form__message.is-error {
    color: #dc2626;
  }

  .inquiry-form__message.is-success {
    color: #059669;
  }

  @media (max-width: 768px) {
    .inquiry-form__grid {
      grid-template-columns: 1fr;
    }

    .inquiry-box {
      padding: 20px;
    }
  }
</style>

<script>
  import { postInquiry } from "../../lib/api/inquiries";

  const forms = document.querySelectorAll("[data-inquiry-form]");

  forms.forEach((formElement) => {
    if (!(formElement instanceof HTMLFormElement)) return;

    const submitButton = formElement.querySelector("[data-submit-button]");
    const messageElement = formElement.querySelector("[data-form-message]");

    if (!(submitButton instanceof HTMLButtonElement)) return;
    if (!(messageElement instanceof HTMLElement)) return;

    formElement.addEventListener("submit", async (event) => {
      event.preventDefault();

      const inquiryType = formElement.dataset.inquiryType ?? "general";
      const propertySlug = formElement.dataset.propertySlug?.trim() || null;

      const formData = new FormData(formElement);

      const name = String(formData.get("name") ?? "").trim();
      const email = String(formData.get("email") ?? "").trim();
      const phone = String(formData.get("phone") ?? "").trim();
      const message = String(formData.get("message") ?? "").trim();

      messageElement.textContent = "";
      messageElement.classList.remove("is-error", "is-success");
      submitButton.disabled = true;
      submitButton.textContent = "送信中...";

      try {
        await postInquiry({
          inquiryType,
          propertySlug,
          name,
          email,
          phone,
          message,
        });

        formElement.reset();
        messageElement.textContent =
          "お問い合わせを受け付けました。担当者より順次ご連絡いたします。";
        messageElement.classList.add("is-success");
      } catch (error) {
        const errorMessage =
          error instanceof Error
            ? error.message
            : "問い合わせの送信に失敗しました。";

        messageElement.textContent = errorMessage;
        messageElement.classList.add("is-error");
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "送信する";
      }
    });
  });
</script>