---
export const prerender = false;

import SearchForm from "../components/search/SearchForm.astro";
import PublicSiteLayout from "../layouts/PublicSiteLayout.astro";
import { getPublicFeatureOptions } from "../lib/api/features";
import {
  normalizePropertySearchParams,
  parsePropertySearchParams,
} from "../lib/search/query";

const searchParams = new URL(Astro.request.url).searchParams;
const initialValues = normalizePropertySearchParams(
  parsePropertySearchParams(searchParams),
);

const featureOptions = await getPublicFeatureOptions();
---

<PublicSiteLayout
  title="物件検索 | 不動産サイト"
  description="土地・戸建ての条件検索ページです。エリアや価格、面積などから物件を探せます。"
>
  <div class="search-page">
    <section class="search-hero">
      <div class="container">
        <div class="search-hero__inner">
          <p class="search-hero__eyebrow">PROPERTY SEARCH</p>
          <h1 class="search-hero__title">物件を探す</h1>
          <p class="search-hero__lead">
            エリア・価格・面積などの条件から、希望に近い土地や戸建てを検索できます。
          </p>
        </div>
      </div>
    </section>

    <section class="search-content">
      <div class="container">
        <div class="search-panel">
          <div class="search-panel__header">
            <p class="search-panel__eyebrow">SEARCH CONDITION</p>
            <h2>検索条件を入力</h2>
            <p>
              土地・戸建ての種別やエリア、価格帯などを指定して物件を探せます。
            </p>
          </div>

          <SearchForm initialValues={initialValues} featureOptions={featureOptions} />
        </div>
      </div>
    </section>
  </div>
</PublicSiteLayout>

<style>
  .search-page {
    background: #ffffff;
  }

  .search-hero {
    position: relative;
    overflow: hidden;
    padding: 84px 0 72px;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.88) 0%,
        rgba(255, 255, 255, 0.72) 48%,
        rgba(255, 255, 255, 0.38) 100%
      ),
      url("/images/sections/hero-bg.jpg");
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(138, 31, 15, 0.12);
  }

  .search-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(46, 10, 5, 0.05);
    pointer-events: none;
  }

  .search-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .search-hero__eyebrow {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .search-hero__title {
    margin: 0 0 16px;
    color: var(--color-text);
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .search-hero__lead {
    margin: 0;
    max-width: 680px;
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.9;
  }

  .search-content {
    padding: 72px 0 96px;
    background: #ffffff;
  }

  .search-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.96);
    padding: 36px;
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
  }

  .search-panel::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 5px;
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-strong) 100%
    );
  }

  .search-panel__header {
    margin-bottom: 30px;
  }

  .search-panel__eyebrow {
    margin: 0 0 10px;
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .search-panel__header h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.3;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .search-panel__header p {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .search-hero {
      padding: 64px 0 52px;
    }

    .search-content {
      padding: 48px 0 72px;
    }

    .search-panel {
      padding: 28px 22px;
      border-radius: 22px;
    }
  }
</style>