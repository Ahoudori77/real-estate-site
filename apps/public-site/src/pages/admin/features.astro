---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="こだわり条件 管理"
  description="こだわり条件の追加と編集を行う"
  currentSection="features"
>
  <section class="admin-section">
    <div class="admin-section__panel">
      <div id="admin-features-root">
        <p class="admin-loading">こだわり条件一覧を読み込み中...</p>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  import { fetchDetail, escapeHtml } from "../../lib/admin/client";
  import { createFeature, updateFeature, deleteFeature } from "../../lib/admin/features";

  const root = document.getElementById("admin-features-root");

  const slugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;

  const renderError = (message) => {
    if (!root) return;
    root.innerHTML = `<p class="admin-error">${escapeHtml(message)}</p>`;
  };

  const normalizeSlug = (value) =>
    String(value)
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  const toSortOrder = (value) => {
    if (value === "" || value === null || value === undefined) return 0;

    const num = Number(value);
    return Number.isFinite(num) ? num : 0;
  };

  const validateFeaturePayload = (payload) => {
    const requiredFields = [
      ["識別子（slug）", payload.slug],
      ["表示名", payload.name],
      ["カテゴリ", payload.category],
    ];

    const missingField = requiredFields.find(([, value]) => !value);

    if (missingField) {
      throw new Error(`${missingField[0]}を入力してください。`);
    }

    if (!slugPattern.test(payload.slug)) {
      throw new Error("識別子（slug）は英小文字・数字・ハイフンのみで入力してください。例: near-school");
    }

    if (!Number.isInteger(payload.sortOrder) || payload.sortOrder < 0) {
      throw new Error("表示順は0以上の整数で入力してください。");
    }
  };

  const buildPayloadFromForm = (form) => {
    const formData = new FormData(form);

    return {
      slug: normalizeSlug(formData.get("slug") ?? ""),
      name: String(formData.get("name") ?? "").trim(),
      category: String(formData.get("category") ?? "").trim(),
      sortOrder: toSortOrder(formData.get("sortOrder")),
    };
  };

  const bindSlugInputs = () => {
    if (!root) return;

    root.querySelectorAll('input[name="slug"]').forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;

      input.addEventListener("blur", () => {
        input.value = normalizeSlug(input.value);
      });
    });
  };

  const bindCreateForm = () => {
    if (!root) return;

    const form = root.querySelector("[data-admin-feature-create-form]");
    const messageBox = root.querySelector("[data-admin-feature-create-message]");
    const button = root.querySelector("[data-admin-feature-create-button]");

    if (!(form instanceof HTMLFormElement)) return;
    if (!(messageBox instanceof HTMLParagraphElement)) return;
    if (!(button instanceof HTMLButtonElement)) return;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();

        messageBox.textContent = "必須項目を入力してください。";
        messageBox.className = "admin-error";
        return;
      }

      messageBox.textContent = "";
      messageBox.className = "admin-card__text";

      const payload = buildPayloadFromForm(form);

      try {
        validateFeaturePayload(payload);

        button.disabled = true;
        button.textContent = "追加中...";

        await createFeature(payload);
        await load("こだわり条件を追加しました。");
      } catch (error) {
        messageBox.textContent =
          error instanceof Error ? error.message : "こだわり条件の追加に失敗しました。";
        messageBox.className = "admin-error";

        button.disabled = false;
        button.textContent = "追加する";
      }
    });
  };

  const bindEditForms = () => {
    if (!root) return;

    const forms = root.querySelectorAll("[data-admin-feature-edit-form]");

    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;

      const featureId = form.dataset.featureId ?? "";
      const messageBox = form.querySelector("[data-admin-feature-edit-message]");
      const saveButton = form.querySelector("[data-admin-feature-edit-button]");

      if (!(messageBox instanceof HTMLParagraphElement)) return;
      if (!(saveButton instanceof HTMLButtonElement)) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();

          messageBox.textContent = "必須項目を入力してください。";
          messageBox.className = "admin-error";
          return;
        }

        messageBox.textContent = "";
        messageBox.className = "admin-card__text";

        const payload = buildPayloadFromForm(form);

        try {
          validateFeaturePayload(payload);

          saveButton.disabled = true;
          saveButton.textContent = "保存中...";

          await updateFeature(featureId, payload);
          await load("こだわり条件を保存しました。");
        } catch (error) {
          messageBox.textContent =
            error instanceof Error ? error.message : "こだわり条件の更新に失敗しました。";
          messageBox.className = "admin-error";

          saveButton.disabled = false;
          saveButton.textContent = "保存する";
        }
      });
    });
  };

  const bindDeleteButtons = () => {
    if (!root) return;

    const buttons = root.querySelectorAll("[data-admin-feature-delete-button]");

    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      const featureId = button.dataset.featureId ?? "";
      const form = button.closest("[data-admin-feature-edit-form]");
      if (!(form instanceof HTMLFormElement)) return;

      const messageBox = form.querySelector("[data-admin-feature-edit-message]");
      if (!(messageBox instanceof HTMLParagraphElement)) return;

      button.addEventListener("click", async () => {
        const confirmed = window.confirm("このこだわり条件を削除しますか？");
        if (!confirmed) return;

        messageBox.textContent = "";
        messageBox.className = "admin-card__text";

        button.disabled = true;
        button.textContent = "削除中...";

        try {
          await deleteFeature(featureId);
          await load("こだわり条件を削除しました。");
        } catch (error) {
          messageBox.textContent =
            error instanceof Error ? error.message : "こだわり条件の削除に失敗しました。";
          messageBox.className = "admin-error";

          button.disabled = false;
          button.textContent = "削除する";
        }
      });
    });
  };

  const render = (items, flashMessage = "") => {
    if (!root) return;

    root.innerHTML = `
      <div class="admin-form__actions">
        <a href="/admin/properties" class="admin-button admin-button--secondary">物件一覧へ戻る</a>
      </div>

      <div class="admin-section__panel" style="margin-top: 24px;">
        <h2 class="admin-card__title">新規こだわり条件 追加</h2>

        <form class="admin-form" data-admin-feature-create-form>
          <p class="${flashMessage ? "admin-success-text" : "admin-card__text"}" data-admin-feature-create-message>
            ${escapeHtml(flashMessage)}
          </p>

          <div class="admin-form-grid">
            <div class="admin-form-field">
              <label>識別子（slug）</label>
              <input
                type="text"
                name="slug"
                placeholder="near-school"
                pattern="[a-z0-9]+(-[a-z0-9]+)*"
                title="英小文字・数字・ハイフンのみで入力してください。例: near-school"
                required
              />
            </div>

            <div class="admin-form-field">
              <label>表示名</label>
              <input type="text" name="name" placeholder="学校近く" required />
            </div>

            <div class="admin-form-field">
              <label>カテゴリ</label>
              <input type="text" name="category" placeholder="amenity" required />
            </div>

            <div class="admin-form-field">
              <label>表示順</label>
              <input type="number" name="sortOrder" value="0" min="0" step="1" required />
            </div>
          </div>

          <div class="admin-form__actions" style="margin-top: 16px;">
            <button type="submit" class="admin-button" data-admin-feature-create-button>追加する</button>
          </div>
        </form>
      </div>

      <div class="admin-section__panel" style="margin-top: 24px;">
        <h2 class="admin-card__title">既存こだわり条件 一覧</h2>

        ${
          items.length
            ? `
              <div class="admin-feature-list">
                ${items
                  .map(
                    (item) => `
                      <form class="admin-feature-card" data-admin-feature-edit-form data-feature-id="${escapeHtml(item.id)}">
                        <div class="admin-feature-card__header">
                          <div>
                            <div class="admin-feature-card__id">ID: ${escapeHtml(item.id)}</div>
                            <div class="admin-feature-card__usage">使用中: ${escapeHtml(item.usageCount ?? 0)} 件</div>
                          </div>
                          <div class="admin-feature-card__actions">
                            <button type="submit" class="admin-button" data-admin-feature-edit-button>保存する</button>
                            <button
                              type="button"
                              class="admin-button admin-button--danger"
                              data-admin-feature-delete-button
                              data-feature-id="${escapeHtml(item.id)}"
                            >
                              削除する
                            </button>
                          </div>
                        </div>

                        <p class="admin-card__text" data-admin-feature-edit-message></p>

                        <div class="admin-form-grid">
                          <div class="admin-form-field">
                            <label>識別子（slug）</label>
                            <input
                              type="text"
                              name="slug"
                              value="${escapeHtml(item.slug)}"
                              pattern="[a-z0-9]+(-[a-z0-9]+)*"
                              title="英小文字・数字・ハイフンのみで入力してください。例: near-school"
                              required
                            />
                          </div>

                          <div class="admin-form-field">
                            <label>表示名</label>
                            <input type="text" name="name" value="${escapeHtml(item.name)}" required />
                          </div>

                          <div class="admin-form-field">
                            <label>カテゴリ</label>
                            <input type="text" name="category" value="${escapeHtml(item.category ?? "")}" required />
                          </div>

                          <div class="admin-form-field">
                            <label>表示順</label>
                            <input type="number" name="sortOrder" value="${escapeHtml(item.sortOrder)}" min="0" step="1" required />
                          </div>
                        </div>
                      </form>
                    `,
                  )
                  .join("")}
              </div>
            `
            : '<p class="admin-empty">こだわり条件はまだ登録されていません。</p>'
        }
      </div>
    `;

    bindSlugInputs();
    bindCreateForm();
    bindEditForms();
    bindDeleteButtons();
  };

  const load = async (flashMessage = "") => {
    try {
      const items = await fetchDetail("/api/admin/features");
      render(items, flashMessage);
    } catch (error) {
      console.error("[admin features] load failed", error);
      renderError(error instanceof Error ? error.message : "こだわり条件一覧の取得に失敗しました。");
    }
  };

  void load();
</script>

<style>
  .admin-feature-list {
    display: grid;
    gap: 16px;
    margin-top: 16px;
  }

  .admin-feature-card {
    border: 1px solid #d7dce5;
    border-radius: 12px;
    padding: 16px;
    background: #fff;
  }

  .admin-feature-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .admin-feature-card__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .admin-feature-card__id {
    font-size: 14px;
    color: #4b5563;
  }

  .admin-feature-card__usage {
    font-size: 14px;
    color: #6b7280;
    margin-top: 4px;
  }

  .admin-button--danger {
    background: #b91c1c;
    color: #fff;
    border-color: #b91c1c;
  }
</style>