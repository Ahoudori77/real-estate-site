---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="feature 管理"
  description="feature の追加と編集を行う"
  currentSection="features"
>
  <section class="admin-section">
    <div class="admin-section__panel">
      <div id="admin-features-root">
        <p class="admin-loading">feature 一覧を読み込み中...</p>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  import { fetchDetail, escapeHtml } from "../../lib/admin/client";
  import { createFeature, updateFeature, deleteFeature } from "../../lib/admin/features";

  const root = document.getElementById("admin-features-root");

  const renderError = (message) => {
    if (!root) return;
    root.innerHTML = `<p class="admin-error">${escapeHtml(message)}</p>`;
  };

  const toSortOrder = (value) => {
    const num = Number(value);
    return Number.isNaN(num) ? 0 : num;
  };

  const bindCreateForm = () => {
    if (!root) return;

    const form = root.querySelector("[data-admin-feature-create-form]");
    const messageBox = root.querySelector("[data-admin-feature-create-message]");
    const button = root.querySelector("[data-admin-feature-create-button]");

    if (!(form instanceof HTMLFormElement)) return;
    if (!(messageBox instanceof HTMLParagraphElement)) return;
    if (!(button instanceof HTMLButtonElement)) return;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      messageBox.textContent = "";
      messageBox.className = "admin-card__text";

      button.disabled = true;
      button.textContent = "追加中...";

      const formData = new FormData(form);

      const payload = {
        slug: String(formData.get("slug") ?? "").trim(),
        name: String(formData.get("name") ?? "").trim(),
        category: String(formData.get("category") ?? "").trim(),
        sortOrder: toSortOrder(formData.get("sortOrder")),
      };

      try {
        await createFeature(payload);
        await load("feature を追加しました。");
      } catch (error) {
        messageBox.textContent =
          error instanceof Error ? error.message : "feature の追加に失敗しました。";
        messageBox.className = "admin-error";
        button.disabled = false;
        button.textContent = "追加する";
      }
    });
  };

  const bindEditForms = () => {
    if (!root) return;

    const forms = root.querySelectorAll("[data-admin-feature-edit-form]");

    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;

      const featureId = form.dataset.featureId ?? "";
      const messageBox = form.querySelector("[data-admin-feature-edit-message]");
      const saveButton = form.querySelector("[data-admin-feature-edit-button]");

      if (!(messageBox instanceof HTMLParagraphElement)) return;
      if (!(saveButton instanceof HTMLButtonElement)) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        messageBox.textContent = "";
        messageBox.className = "admin-card__text";

        saveButton.disabled = true;
        saveButton.textContent = "保存中...";

        const formData = new FormData(form);

        const payload = {
          slug: String(formData.get("slug") ?? "").trim(),
          name: String(formData.get("name") ?? "").trim(),
          category: String(formData.get("category") ?? "").trim(),
          sortOrder: toSortOrder(formData.get("sortOrder")),
        };

        try {
          await updateFeature(featureId, payload);
          await load("feature を保存しました。");
        } catch (error) {
          messageBox.textContent =
            error instanceof Error ? error.message : "feature の更新に失敗しました。";
          messageBox.className = "admin-error";
          saveButton.disabled = false;
          saveButton.textContent = "保存する";
        }
      });
    });
  };

  const bindDeleteButtons = () => {
    if (!root) return;

    const buttons = root.querySelectorAll("[data-admin-feature-delete-button]");

    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      const featureId = button.dataset.featureId ?? "";
      const form = button.closest("[data-admin-feature-edit-form]");
      if (!(form instanceof HTMLFormElement)) return;

      const messageBox = form.querySelector("[data-admin-feature-edit-message]");
      if (!(messageBox instanceof HTMLParagraphElement)) return;

      button.addEventListener("click", async () => {
        const confirmed = window.confirm("この feature を削除しますか？");
        if (!confirmed) return;

        messageBox.textContent = "";
        messageBox.className = "admin-card__text";

        button.disabled = true;
        button.textContent = "削除中...";

        try {
          await deleteFeature(featureId);
          await load("feature を削除しました。");
        } catch (error) {
          messageBox.textContent =
            error instanceof Error ? error.message : "feature の削除に失敗しました。";
          messageBox.className = "admin-error";
          button.disabled = false;
          button.textContent = "削除する";
        }
      });
    });
  };

  const render = (items, flashMessage = "") => {
    if (!root) return;

    root.innerHTML = `
      <div class="admin-form__actions">
        <a href="/admin/properties" class="admin-button admin-button--secondary">物件一覧へ戻る</a>
      </div>

      <div class="admin-section__panel" style="margin-top: 24px;">
        <h2 class="admin-card__title">新規 feature 追加</h2>

        <form class="admin-form" data-admin-feature-create-form novalidate>
          <p class="${flashMessage ? "admin-success-text" : "admin-card__text"}" data-admin-feature-create-message>
            ${escapeHtml(flashMessage)}
          </p>

          <div class="admin-form-grid">
            <div class="admin-form-field">
              <label>slug</label>
              <input type="text" name="slug" placeholder="near-school" />
            </div>

            <div class="admin-form-field">
              <label>name</label>
              <input type="text" name="name" placeholder="学校近く" />
            </div>

            <div class="admin-form-field">
              <label>category</label>
              <input type="text" name="category" placeholder="amenity" />
            </div>

            <div class="admin-form-field">
              <label>sortOrder</label>
              <input type="number" name="sortOrder" value="0" />
            </div>
          </div>

          <div class="admin-form__actions" style="margin-top: 16px;">
            <button type="submit" class="admin-button" data-admin-feature-create-button>追加する</button>
          </div>
        </form>
      </div>

      <div class="admin-section__panel" style="margin-top: 24px;">
        <h2 class="admin-card__title">既存 feature 一覧</h2>

        ${
          items.length
            ? `
              <div class="admin-feature-list">
                ${items
                  .map(
                    (item) => `
                      <form class="admin-feature-card" data-admin-feature-edit-form data-feature-id="${escapeHtml(item.id)}" novalidate>
                        <div class="admin-feature-card__header">
                          <div>
                            <div class="admin-feature-card__id">ID: ${escapeHtml(item.id)}</div>
                            <div class="admin-feature-card__usage">使用中: ${escapeHtml(item.usageCount ?? 0)} 件</div>
                          </div>
                          <div class="admin-feature-card__actions">
                            <button type="submit" class="admin-button" data-admin-feature-edit-button>保存する</button>
                            <button
                              type="button"
                              class="admin-button admin-button--danger"
                              data-admin-feature-delete-button
                              data-feature-id="${escapeHtml(item.id)}"
                            >
                              削除する
                            </button>
                          </div>
                        </div>

                        <p class="admin-card__text" data-admin-feature-edit-message></p>

                        <div class="admin-form-grid">
                          <div class="admin-form-field">
                            <label>slug</label>
                            <input type="text" name="slug" value="${escapeHtml(item.slug)}" />
                          </div>

                          <div class="admin-form-field">
                            <label>name</label>
                            <input type="text" name="name" value="${escapeHtml(item.name)}" />
                          </div>

                          <div class="admin-form-field">
                            <label>category</label>
                            <input type="text" name="category" value="${escapeHtml(item.category ?? "")}" />
                          </div>

                          <div class="admin-form-field">
                            <label>sortOrder</label>
                            <input type="number" name="sortOrder" value="${escapeHtml(item.sortOrder)}" />
                          </div>
                        </div>
                      </form>
                    `,
                  )
                  .join("")}
              </div>
            `
            : '<p class="admin-empty">feature はまだ登録されていません。</p>'
        }
      </div>
    `;

    bindCreateForm();
    bindEditForms();
    bindDeleteButtons();
  };

  const load = async (flashMessage = "") => {
    try {
      const items = await fetchDetail("/api/admin/features");
      render(items, flashMessage);
    } catch (error) {
      console.error("[admin features] load failed", error);
      renderError(error instanceof Error ? error.message : "feature 一覧の取得に失敗しました。");
    }
  };

  void load();
</script>

<style>
  .admin-feature-list {
    display: grid;
    gap: 16px;
    margin-top: 16px;
  }

  .admin-feature-card {
    border: 1px solid #d7dce5;
    border-radius: 12px;
    padding: 16px;
    background: #fff;
  }

  .admin-feature-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .admin-feature-card__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .admin-feature-card__id {
    font-size: 14px;
    color: #4b5563;
  }

  .admin-feature-card__usage {
    font-size: 14px;
    color: #6b7280;
    margin-top: 4px;
  }

  .admin-button--danger {
    background: #b91c1c;
    color: #fff;
    border-color: #b91c1c;
  }
</style>