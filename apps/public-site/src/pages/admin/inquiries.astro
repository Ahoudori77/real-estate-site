---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="問い合わせ管理"
  description="問い合わせ件数と内容を確認しやすい形に整理しています。"
  currentSection="inquiries"
>
  <section class="admin-section">
    <div class="admin-section__panel">
      <div id="admin-inquiries-root">
        <p class="admin-loading">問い合わせ一覧を読み込み中...</p>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  import { fetchList, escapeHtml, formatDateTime } from "../../lib/admin/client";

  const root = document.getElementById("admin-inquiries-root");

  const normalizeListResponse = (response) => {
    if (Array.isArray(response)) {
      return {
        items: response,
        total: response.length,
      };
    }

    const items = Array.isArray(response?.items) ? response.items : [];

    return {
      items,
      total: Number(response?.total ?? items.length),
    };
  };

  const getInquiryName = (item) =>
    item.name ?? item.customerName ?? item.contactName ?? "-";

  const getInquiryEmail = (item) =>
    item.email ?? item.mail ?? "-";

  const getInquiryPhone = (item) =>
    item.phone ?? item.phoneNumber ?? "-";

  const getInquiryProperty = (item) =>
    item.propertyTitle ?? item.propertyName ?? item.propertySlug ?? "-";

  const getInquiryCreatedAt = (item) =>
    item.createdAt ?? item.inquiredAt ?? item.submittedAt ?? null;

  const getInquiryMessage = (item) =>
    item.message ?? item.body ?? item.inquiryBody ?? "";

  const renderError = (message) => {
    if (!root) return;
    root.innerHTML = `<p class="admin-error">${escapeHtml(message)}</p>`;
  };

  const render = (response) => {
    if (!root) return;

    const { items, total } = normalizeListResponse(response);
    const withPropertyCount = items.filter((item) => getInquiryProperty(item) !== "-").length;
    const withMessageCount = items.filter((item) => String(getInquiryMessage(item)).trim() !== "").length;

    root.innerHTML = `
      <div class="admin-summary-grid">
        <div class="admin-summary-card">
          <p class="admin-summary-card__label">総問い合わせ件数</p>
          <p class="admin-summary-card__value">${escapeHtml(total)}</p>
          <p class="admin-summary-card__note">管理対象の問い合わせ総数です。</p>
        </div>

        <div class="admin-summary-card">
          <p class="admin-summary-card__label">物件紐づきあり</p>
          <p class="admin-summary-card__value">${escapeHtml(withPropertyCount)}</p>
          <p class="admin-summary-card__note">対象物件が判別できる問い合わせ件数です。</p>
        </div>

        <div class="admin-summary-card">
          <p class="admin-summary-card__label">本文あり</p>
          <p class="admin-summary-card__value">${escapeHtml(withMessageCount)}</p>
          <p class="admin-summary-card__note">本文を含む問い合わせ件数です。</p>
        </div>
      </div>

      <div class="admin-section__panel" style="margin-top: 20px;">
        <div class="admin-list-header">
          <div>
            <h2 class="admin-list-header__title">問い合わせ一覧</h2>
            <p class="admin-list-header__meta">新しい順に確認できるよう整理してください。</p>
          </div>
        </div>

        ${
          items.length
            ? `
              <div class="admin-inquiry-list">
                ${items
                  .map(
                    (item) => `
                      <article class="admin-inquiry-card">
                        <div class="admin-inquiry-card__header">
                          <div>
                            <h3 class="admin-inquiry-card__name">${escapeHtml(getInquiryName(item))}</h3>
                            <p class="admin-inline-text-muted">
                              受付日時: ${escapeHtml(formatDateTime(getInquiryCreatedAt(item)))}
                            </p>
                          </div>

                          <div class="admin-badge-row">
                            <span class="admin-badge admin-badge--neutral">
                              物件: ${escapeHtml(getInquiryProperty(item))}
                            </span>
                          </div>
                        </div>

                        <div class="admin-inquiry-card__meta">
                          <div><strong>メール:</strong> ${escapeHtml(getInquiryEmail(item))}</div>
                          <div><strong>電話:</strong> ${escapeHtml(getInquiryPhone(item))}</div>
                        </div>

                        <div class="admin-inquiry-card__message">
                          <p class="admin-inquiry-card__message-label">本文</p>
                          <p class="admin-inquiry-card__message-text">${escapeHtml(getInquiryMessage(item) || "本文は登録されていません。")}</p>
                        </div>
                      </article>
                    `,
                  )
                  .join("")}
              </div>
            `
            : `
              <div class="admin-empty-state">
                <p class="admin-empty-state__title">問い合わせはまだありません</p>
                <p class="admin-empty-state__text">公開サイトから送信されると、ここに一覧表示されます。</p>
              </div>
            `
        }
      </div>
    `;
  };

  const load = async () => {
    try {
      const response = await fetchList("/api/admin/inquiries");
      render(response);
    } catch (error) {
      renderError(error instanceof Error ? error.message : "問い合わせ一覧の取得に失敗しました。");
    }
  };

  void load();
</script>
<style>
  :global(.admin-inquiry-list) {
    display: grid;
    gap: 20px;
    margin-top: 18px;
  }

  :global(.admin-inquiry-card) {
    min-width: 0;
    border: 1px solid #d8dee8;
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  :global(.admin-inquiry-card__header) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    padding: 18px 20px;
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    border-bottom: 1px solid #eef2f7;
  }

  :global(.admin-inquiry-card__name) {
    margin: 0;
    font-size: 18px;
    line-height: 1.4;
    font-weight: 800;
    color: #111827;
  }

  :global(.admin-inquiry-card__header .admin-inline-text-muted) {
    margin-top: 6px;
  }

  :global(.admin-inquiry-card .admin-badge-row) {
    justify-content: flex-end;
  }

  :global(.admin-inquiry-card .admin-badge) {
    max-width: 360px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.admin-inquiry-card__meta) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    padding: 16px 20px;
    color: #374151;
    font-size: 14px;
    border-bottom: 1px solid #eef2f7;
  }

  :global(.admin-inquiry-card__meta div) {
    min-width: 0;
    padding: 12px 14px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #f8fafc;
    overflow-wrap: anywhere;
  }

  :global(.admin-inquiry-card__meta strong) {
    display: block;
    margin-bottom: 4px;
    color: #6b7280;
    font-size: 12px;
    font-weight: 800;
  }

  :global(.admin-inquiry-card__message) {
    margin: 0;
    padding: 18px 20px 20px;
  }

  :global(.admin-inquiry-card__message-label) {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 800;
    color: #6b7280;
  }

  :global(.admin-inquiry-card__message-text) {
    display: block;
    min-height: 96px;
    margin: 0;
    padding: 14px 16px;
    border: 1px solid #d8dee8;
    border-radius: 12px;
    background: #f4f7fb;
    color: #111827;
    line-height: 1.8;
    text-align: left;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (max-width: 720px) {
    :global(.admin-inquiry-card__header) {
      display: grid;
    }

    :global(.admin-inquiry-card .admin-badge-row) {
      justify-content: flex-start;
    }

    :global(.admin-inquiry-card .admin-badge) {
      max-width: 100%;
    }

    :global(.admin-inquiry-card__meta) {
      grid-template-columns: 1fr;
    }
  }
</style>