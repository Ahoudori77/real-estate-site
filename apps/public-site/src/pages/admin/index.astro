---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="ダッシュボード"
  description="物件・こだわり条件・問い合わせの状況をまとめて確認できます。"
>
  <section class="dashboard-hero">
    <div>
      <p class="dashboard-hero__eyebrow">ADMIN OVERVIEW</p>
      <h2 class="dashboard-hero__title">管理状況を確認</h2>
      <p class="dashboard-hero__text">
        公開中の物件数、こだわり条件、問い合わせ状況をここから確認できます。
      </p>
    </div>

    <div class="dashboard-hero__actions">
      <a href="/admin/properties/new" class="dashboard-button dashboard-button--primary">
        新規物件を追加
      </a>
      <a href="/admin/properties" class="dashboard-button">
        物件一覧を見る
      </a>
    </div>
  </section>

  <section class="dashboard-summary-grid" aria-label="管理サマリー">
    <a href="/admin/properties" class="dashboard-summary-card dashboard-summary-card--blue">
      <p class="dashboard-summary-card__label">物件</p>
      <p class="dashboard-summary-card__value" data-admin-stat="properties">読み込み中...</p>
      <p class="dashboard-summary-card__note">公開・下書き・アーカイブを含む登録件数</p>
    </a>

    <a href="/admin/features" class="dashboard-summary-card dashboard-summary-card--green">
      <p class="dashboard-summary-card__label">こだわり条件</p>
      <p class="dashboard-summary-card__value" data-admin-stat="features">読み込み中...</p>
      <p class="dashboard-summary-card__note">検索条件や物件特徴として使う条件数</p>
    </a>

    <a href="/admin/inquiries" class="dashboard-summary-card dashboard-summary-card--orange">
      <p class="dashboard-summary-card__label">問い合わせ</p>
      <p class="dashboard-summary-card__value" data-admin-stat="inquiries">読み込み中...</p>
      <p class="dashboard-summary-card__note">現在確認できる問い合わせ件数</p>
    </a>
  </section>

  <section class="dashboard-grid">
    <article class="dashboard-panel">
      <div class="dashboard-panel__header">
        <div>
          <p class="dashboard-panel__eyebrow">QUICK ACTION</p>
          <h2 class="dashboard-panel__title">よく使う操作</h2>
        </div>
      </div>

      <div class="dashboard-action-list">
        <a href="/admin/properties/new" class="dashboard-action-card">
          <span class="dashboard-action-card__icon">＋</span>
          <span>
            <strong>新規物件を追加</strong>
            <small>最低限の情報を入力して物件を作成します</small>
          </span>
        </a>

        <a href="/admin/properties" class="dashboard-action-card">
          <span class="dashboard-action-card__icon">家</span>
          <span>
            <strong>物件を管理</strong>
            <small>物件の編集・画像管理・公開状態を確認します</small>
          </span>
        </a>

        <a href="/admin/features" class="dashboard-action-card">
          <span class="dashboard-action-card__icon">条</span>
          <span>
            <strong>こだわり条件を管理</strong>
            <small>検索フォームや物件特徴に使う条件を編集します</small>
          </span>
        </a>

        <a href="/admin/inquiries" class="dashboard-action-card">
          <span class="dashboard-action-card__icon">問</span>
          <span>
            <strong>問い合わせを確認</strong>
            <small>お客様から届いた問い合わせ内容を確認します</small>
          </span>
        </a>
      </div>
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel__header">
        <div>
          <p class="dashboard-panel__eyebrow">LATEST INQUIRIES</p>
          <h2 class="dashboard-panel__title">最新問い合わせ</h2>
        </div>
        <a href="/admin/inquiries" class="dashboard-panel__link">一覧を見る</a>
      </div>

      <div id="admin-dashboard-inquiries">
        <p class="admin-loading">読み込み中...</p>
      </div>
    </article>
  </section>
</AdminLayout>

<script>
  import { fetchList, escapeHtml, formatDateTime, truncateText } from "../../lib/admin/client";

  const propertyStat = document.querySelector('[data-admin-stat="properties"]');
  const featureStat = document.querySelector('[data-admin-stat="features"]');
  const inquiryStat = document.querySelector('[data-admin-stat="inquiries"]');
  const latestInquiriesRoot = document.getElementById("admin-dashboard-inquiries");

  const badgeClassFromInquiryStatus = (status) => {
    switch ((status ?? "").toLowerCase()) {
      case "new":
        return "admin-badge admin-badge--warning";
      case "replied":
      case "resolved":
      case "closed":
        return "admin-badge admin-badge--success";
      default:
        return "admin-badge admin-badge--neutral";
    }
  };

  const inquiryStatusLabel = (status) => {
    switch ((status ?? "").toLowerCase()) {
      case "new":
        return "新規";
      case "pending":
        return "対応中";
      case "replied":
        return "返信済み";
      case "resolved":
        return "完了";
      case "closed":
        return "クローズ";
      default:
        return "未設定";
    }
  };

  const getInquiryName = (item) =>
    item.name ?? item.customerName ?? item.contactName ?? "名前未設定";

  const getInquiryEmail = (item) =>
    item.email ?? item.customerEmail ?? "-";

  const getInquiryCreatedAt = (item) =>
    item.createdAt ?? item.created_at ?? item.receivedAt ?? null;

  const setStat = (element, value) => {
    if (!element) return;
    element.textContent = value;
  };

  const renderLatestInquiries = (items) => {
    if (!latestInquiriesRoot) return;

    if (!items.length) {
      latestInquiriesRoot.innerHTML = `
        <div class="dashboard-empty">
          <p class="dashboard-empty__title">問い合わせはまだありません</p>
          <p class="dashboard-empty__text">問い合わせが届くと、ここに最新の内容が表示されます。</p>
        </div>
      `;
      return;
    }

    latestInquiriesRoot.innerHTML = `
      <div class="dashboard-inquiry-list">
        ${items
          .slice(0, 5)
          .map(
            (item) => `
              <article class="dashboard-inquiry-card">
                <div class="dashboard-inquiry-card__top">
                  <div>
                    <h3 class="dashboard-inquiry-card__name">${escapeHtml(getInquiryName(item))}</h3>
                    <p class="dashboard-inquiry-card__meta">
                      ${escapeHtml(getInquiryEmail(item))}
                      <span>/</span>
                      ${escapeHtml(formatDateTime(getInquiryCreatedAt(item)))}
                    </p>
                  </div>

                  <span class="${badgeClassFromInquiryStatus(item.status)}">
                    ${escapeHtml(inquiryStatusLabel(item.status))}
                  </span>
                </div>

                <p class="dashboard-inquiry-card__message">
                  ${escapeHtml(truncateText(item.message, 120) || "本文なし")}
                </p>
              </article>
            `,
          )
          .join("")}
      </div>
    `;
  };

  const loadDashboard = async () => {
    const [propertiesResult, featuresResult, inquiriesResult] = await Promise.allSettled([
      fetchList("/api/admin/properties"),
      fetchList("/api/admin/features"),
      fetchList("/api/admin/inquiries"),
    ]);

    if (propertiesResult.status === "fulfilled") {
      setStat(propertyStat, `${propertiesResult.value.length}件`);
    } else {
      setStat(propertyStat, "取得失敗");
    }

    if (featuresResult.status === "fulfilled") {
      setStat(featureStat, `${featuresResult.value.length}件`);
    } else {
      setStat(featureStat, "取得失敗");
    }

    if (inquiriesResult.status === "fulfilled") {
      setStat(inquiryStat, `${inquiriesResult.value.length}件`);
      renderLatestInquiries(inquiriesResult.value);
    } else {
      setStat(inquiryStat, "取得失敗");

      if (latestInquiriesRoot) {
        latestInquiriesRoot.innerHTML = `<p class="admin-error">${escapeHtml(
          inquiriesResult.reason instanceof Error
            ? inquiriesResult.reason.message
            : "問い合わせ取得に失敗しました。",
        )}</p>`;
      }
    }
  };

  void loadDashboard();
</script>

<style>
  :global(.dashboard-hero) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    border: 1px solid var(--admin-border-soft);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 34%),
      linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
    padding: 28px;
    box-shadow: var(--admin-shadow);
  }

  :global(.dashboard-hero__eyebrow),
  :global(.dashboard-panel__eyebrow) {
    margin: 0 0 8px;
    color: var(--admin-accent);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  :global(.dashboard-hero__title) {
    margin: 0;
    font-size: 28px;
    line-height: 1.3;
    letter-spacing: -0.03em;
  }

  :global(.dashboard-hero__text) {
    margin: 10px 0 0;
    color: var(--admin-muted);
    font-weight: 600;
    line-height: 1.8;
  }

  :global(.dashboard-hero__actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  :global(.dashboard-button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border: 1px solid var(--admin-border);
    border-radius: 999px;
    background: #ffffff;
    color: var(--admin-text);
    padding: 0 18px;
    font-weight: 800;
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
  }

  :global(.dashboard-button--primary) {
    border-color: var(--admin-accent);
    background: var(--admin-accent);
    color: #ffffff;
  }

  :global(.dashboard-summary-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 20px;
  }

  :global(.dashboard-summary-card) {
    position: relative;
    overflow: hidden;
    display: block;
    border: 1px solid var(--admin-border-soft);
    border-radius: 20px;
    background: #ffffff;
    padding: 22px;
    box-shadow: var(--admin-shadow);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  :global(.dashboard-summary-card:hover) {
    transform: translateY(-2px);
    border-color: rgba(37, 99, 235, 0.35);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
  }

  :global(.dashboard-summary-card::before) {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: var(--admin-accent);
  }

  :global(.dashboard-summary-card--green::before) {
    background: #16a34a;
  }

  :global(.dashboard-summary-card--orange::before) {
    background: #f97316;
  }

  :global(.dashboard-summary-card__label) {
    margin: 0;
    color: var(--admin-muted);
    font-size: 13px;
    font-weight: 800;
  }

  :global(.dashboard-summary-card__value) {
    margin: 8px 0 6px;
    color: var(--admin-text);
    font-size: 36px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  :global(.dashboard-summary-card__note) {
    margin: 0;
    color: var(--admin-muted);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.7;
  }

  :global(.dashboard-grid) {
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 20px;
    margin-top: 20px;
  }

  :global(.dashboard-panel) {
    border: 1px solid var(--admin-border-soft);
    border-radius: 22px;
    background: #ffffff;
    padding: 22px;
    box-shadow: var(--admin-shadow);
  }

  :global(.dashboard-panel__header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  :global(.dashboard-panel__title) {
    margin: 0;
    font-size: 22px;
    line-height: 1.3;
    letter-spacing: -0.03em;
  }

  :global(.dashboard-panel__link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    border: 1px solid var(--admin-border);
    border-radius: 999px;
    padding: 0 12px;
    color: var(--admin-accent);
    font-size: 13px;
    font-weight: 800;
    white-space: nowrap;
  }

  :global(.dashboard-action-list) {
    display: grid;
    gap: 12px;
  }

  :global(.dashboard-action-card) {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    border: 1px solid var(--admin-border-soft);
    border-radius: 16px;
    background: var(--admin-surface-muted);
    padding: 14px;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  :global(.dashboard-action-card:hover) {
    background: #ffffff;
    border-color: rgba(37, 99, 235, 0.32);
    transform: translateX(2px);
  }

  :global(.dashboard-action-card__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: var(--admin-accent-soft);
    color: var(--admin-accent);
    font-weight: 900;
  }

  :global(.dashboard-action-card strong) {
    display: block;
    color: var(--admin-text);
    font-size: 15px;
    line-height: 1.5;
  }

  :global(.dashboard-action-card small) {
    display: block;
    margin-top: 2px;
    color: var(--admin-muted);
    font-size: 12px;
    line-height: 1.6;
    font-weight: 600;
  }

  :global(.dashboard-inquiry-list) {
    display: grid;
    gap: 12px;
  }

  :global(.dashboard-inquiry-card) {
    border: 1px solid var(--admin-border-soft);
    border-radius: 16px;
    background: #ffffff;
    padding: 14px;
  }

  :global(.dashboard-inquiry-card__top) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  :global(.dashboard-inquiry-card__name) {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
  }

  :global(.dashboard-inquiry-card__meta) {
    margin: 3px 0 0;
    color: var(--admin-muted);
    font-size: 12px;
    font-weight: 600;
  }

  :global(.dashboard-inquiry-card__meta span) {
    color: var(--admin-border);
    margin: 0 4px;
  }

  :global(.dashboard-inquiry-card__message) {
    margin: 10px 0 0;
    color: var(--admin-text);
    font-size: 14px;
    line-height: 1.7;
    word-break: break-word;
  }

  :global(.dashboard-empty) {
    border: 1px dashed var(--admin-border);
    border-radius: 16px;
    background: var(--admin-surface-muted);
    padding: 20px;
  }

  :global(.dashboard-empty__title) {
    margin: 0;
    font-weight: 800;
  }

  :global(.dashboard-empty__text) {
    margin: 6px 0 0;
    color: var(--admin-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 1000px) {
    :global(.dashboard-hero) {
      display: grid;
    }

    :global(.dashboard-hero__actions) {
      justify-content: flex-start;
    }

    :global(.dashboard-summary-grid),
    :global(.dashboard-grid) {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    :global(.dashboard-hero),
    :global(.dashboard-panel),
    :global(.dashboard-summary-card) {
      border-radius: 18px;
      padding: 18px;
    }

    :global(.dashboard-hero__title) {
      font-size: 24px;
    }

    :global(.dashboard-summary-card__value) {
      font-size: 30px;
    }
  }
</style>