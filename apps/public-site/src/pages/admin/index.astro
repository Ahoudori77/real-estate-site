---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="ダッシュボード"
  description="物件・特徴・問い合わせの現在状況を確認する"
>
  <section class="admin-card-grid">
    <article class="admin-card">
      <h2 class="admin-card__title">物件管理</h2>
      <p class="admin-card__text">公開中・下書きを含めた物件件数</p>
      <p class="admin-stat" data-admin-stat="properties">読み込み中...</p>
    </article>

    <article class="admin-card">
      <h2 class="admin-card__title">特徴管理</h2>
      <p class="admin-card__text">検索条件で使うこだわり条件の件数</p>
      <p class="admin-stat" data-admin-stat="features">読み込み中...</p>
    </article>

    <article class="admin-card">
      <h2 class="admin-card__title">問い合わせ管理</h2>
      <p class="admin-card__text">現在確認できる問い合わせ件数</p>
      <p class="admin-stat" data-admin-stat="inquiries">読み込み中...</p>
    </article>
  </section>

  <section class="admin-section" style="margin-top: 24px;">
    <div class="admin-section__panel">
      <h2 class="admin-card__title">最新問い合わせ</h2>
      <div id="admin-dashboard-inquiries">
        <p class="admin-loading">読み込み中...</p>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  import { fetchList, escapeHtml, formatDateTime, truncateText } from "../../lib/admin/client";

  const propertyStat = document.querySelector('[data-admin-stat="properties"]');
  const featureStat = document.querySelector('[data-admin-stat="features"]');
  const inquiryStat = document.querySelector('[data-admin-stat="inquiries"]');
  const latestInquiriesRoot = document.getElementById("admin-dashboard-inquiries");

  const badgeClassFromInquiryStatus = (status) => {
    switch ((status ?? "").toLowerCase()) {
      case "new":
        return "admin-badge admin-badge--warning";
      case "replied":
      case "resolved":
      case "closed":
        return "admin-badge admin-badge--success";
      default:
        return "admin-badge admin-badge--neutral";
    }
  };

  const inquiryStatusLabel = (status) => {
    switch ((status ?? "").toLowerCase()) {
      case "new":
        return "新規";
      case "pending":
        return "対応中";
      case "replied":
        return "返信済み";
      case "resolved":
        return "完了";
      case "closed":
        return "クローズ";
      default:
        return "未設定";
    }
  };

  const setStat = (element, value) => {
    if (!element) return;
    element.textContent = value;
  };

  const renderLatestInquiries = (items) => {
    if (!latestInquiriesRoot) return;

    if (!items.length) {
      latestInquiriesRoot.innerHTML = '<p class="admin-empty">問い合わせはまだありません。</p>';
      return;
    }

    latestInquiriesRoot.innerHTML = `
      <div class="admin-list">
        ${items
          .slice(0, 5)
          .map(
            (item) => `
              <article class="admin-list-item">
                <div class="admin-list-item__top">
                  <div class="admin-list-item__title">${escapeHtml(item.name ?? "名前未設定")}</div>
                  <span class="${badgeClassFromInquiryStatus(item.status)}">${escapeHtml(
                    inquiryStatusLabel(item.status),
                  )}</span>
                </div>
                <div class="admin-list-item__meta">
                  ${escapeHtml(item.email ?? "-")} / ${escapeHtml(formatDateTime(item.createdAt))}
                </div>
                <p class="admin-list-item__text">${escapeHtml(truncateText(item.message, 100) || "本文なし")}</p>
              </article>
            `,
          )
          .join("")}
      </div>
    `;
  };

  const loadDashboard = async () => {
    const [propertiesResult, featuresResult, inquiriesResult] = await Promise.allSettled([
      fetchList("/api/admin/properties"),
      fetchList("/api/admin/features"),
      fetchList("/api/admin/inquiries"),
    ]);

    if (propertiesResult.status === "fulfilled") {
      setStat(propertyStat, `${propertiesResult.value.length}件`);
    } else {
      setStat(propertyStat, "取得失敗");
    }

    if (featuresResult.status === "fulfilled") {
      setStat(featureStat, `${featuresResult.value.length}件`);
    } else {
      setStat(featureStat, "取得失敗");
    }

    if (inquiriesResult.status === "fulfilled") {
      setStat(inquiryStat, `${inquiriesResult.value.length}件`);
      renderLatestInquiries(inquiriesResult.value);
    } else {
      setStat(inquiryStat, "取得失敗");
      if (latestInquiriesRoot) {
        latestInquiriesRoot.innerHTML = `<p class="admin-error">${escapeHtml(
          inquiriesResult.reason instanceof Error
            ? inquiriesResult.reason.message
            : "問い合わせ取得に失敗しました。",
        )}</p>`;
      }
    }
  };

  void loadDashboard();
</script>