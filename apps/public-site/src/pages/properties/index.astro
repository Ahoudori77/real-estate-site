---
export const prerender = false;

import Pagination from "../../components/common/Pagination.astro";
import PropertyCard from "../../components/property/PropertyCard.astro";
import PublicSiteLayout from "../../layouts/PublicSiteLayout.astro";
import { getPublicFeatureOptions } from "../../lib/api/features";
import { getProperties } from "../../lib/api/properties";
import {
  buildPropertiesHref,
  getActiveFilterLabels,
  normalizePropertySearchParams,
  parsePropertySearchParams,
} from "../../lib/search/query";
import type { PropertySearchParams } from "../../types/search";

const url = new URL(Astro.request.url);
const params: PropertySearchParams = normalizePropertySearchParams(
  parsePropertySearchParams(url.searchParams),
);

const result = await getProperties(params);

let featureLabelMap: Record<string, string> = {};

try {
  const featureOptions = await getPublicFeatureOptions();
  featureLabelMap = Object.fromEntries(
    featureOptions.map((feature) => [feature.slug, feature.name]),
  );
} catch (error) {
  console.warn("[properties] failed to load feature labels", error);
}

const activeFilters = getActiveFilterLabels(params, featureLabelMap);

const buildSortHref = (sort: "newest" | "price_asc" | "price_desc") =>
  buildPropertiesHref({
    ...params,
    sort,
    page: 1,
  });
---

<PublicSiteLayout
  title="物件一覧 | 不動産サイト"
  description="検索条件に応じた土地・戸建ての物件一覧ページです。"
>
  <div class="properties-page">
    <section class="properties-hero">
      <div class="container">
        <div class="properties-hero__inner">
          <p class="properties-hero__eyebrow">PROPERTY LIST</p>
          <h1 class="properties-hero__title">物件一覧</h1>
          <p class="properties-hero__lead">
            条件に合う物件を一覧で確認できます。気になる物件は詳細ページからご確認ください。
          </p>
        </div>
      </div>
    </section>

    <section class="properties-content">
      <div class="container content-grid">
        <aside class="sidebar">
          <div class="filter-panel">
            <p class="filter-panel__eyebrow">SEARCH FILTER</p>
            <h2>検索条件</h2>

            {activeFilters.length > 0 ? (
              <ul class="filter-list">
                {activeFilters.map((filter) => (
                  <li>{filter}</li>
                ))}
              </ul>
            ) : (
              <p class="muted">条件指定なしで全件表示しています。</p>
            )}

            <a
              href="/search"
              class="search-link"
              data-search-page-link
            >
              条件を変更する
            </a>
          </div>
        </aside>

        <section class="main-column">
          <div class="toolbar">
            <div>
              <p class="toolbar-eyebrow">RESULT</p>
              <p class="result-count">
                {result.total}件中{" "}
                {result.total === 0 ? 0 : (result.page - 1) * result.pageSize + 1}
                {" "}〜{" "}
                {Math.min(result.page * result.pageSize, result.total)}
                {" "}件を表示
              </p>
            </div>

            <div class="sort-links" aria-label="並び替え">
              <a
                href={buildSortHref("newest")}
                class:list={[
                  "sort-link",
                  params.sort === "newest" && "active",
                ]}
              >
                新着順
              </a>

              <a
                href={buildSortHref("price_asc")}
                class:list={[
                  "sort-link",
                  params.sort === "price_asc" && "active",
                ]}
              >
                価格が安い順
              </a>

              <a
                href={buildSortHref("price_desc")}
                class:list={[
                  "sort-link",
                  params.sort === "price_desc" && "active",
                ]}
              >
                価格が高い順
              </a>
            </div>
          </div>

          {result.items.length > 0 ? (
            <>
              <div class="card-list">
                {result.items.map((property) => (
                  <PropertyCard property={property} />
                ))}
              </div>

              <Pagination
                currentPage={result.page}
                totalPages={result.totalPages}
                params={params}
              />
            </>
          ) : (
            <section class="empty-state">
              <div class="empty-state-inner">
                <p class="empty-state__eyebrow">NO RESULT</p>
                <h2>該当する物件が見つかりませんでした</h2>
                <p>条件を変更して再度お試しください。</p>
                <a
                  href="/search"
                  class="empty-state-link"
                  data-search-page-link
                >
                  検索条件を見直す
                </a>
              </div>
            </section>
          )}
        </section>
      </div>
    </section>
  </div>

  <script>
    const searchPageLinks = document.querySelectorAll("[data-search-page-link]");
    const currentQuery = window.location.search || "";

    searchPageLinks.forEach((link) => {
      if (link instanceof HTMLAnchorElement) {
        link.href = `/search${currentQuery}`;
      }
    });
  </script>
</PublicSiteLayout>

<style>
  .properties-page {
    background: #ffffff;
  }

  .properties-hero {
    position: relative;
    overflow: hidden;
    padding: 84px 0 72px;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.9) 0%,
        rgba(255, 255, 255, 0.72) 48%,
        rgba(255, 255, 255, 0.38) 100%
      ),
      url("/images/sections/hero-bg.jpg");
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(138, 31, 15, 0.12);
  }

  .properties-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(46, 10, 5, 0.05);
    pointer-events: none;
  }

  .properties-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .properties-hero__eyebrow,
  .filter-panel__eyebrow,
  .toolbar-eyebrow,
  .empty-state__eyebrow {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .properties-hero__title {
    margin: 0 0 16px;
    color: var(--color-text);
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .properties-hero__lead {
    margin: 0;
    max-width: 680px;
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.9;
  }

  .properties-content {
    padding: 72px 0 96px;
    background: #ffffff;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .sidebar,
  .main-column {
    min-width: 0;
  }

  .filter-panel {
    position: sticky;
    top: 24px;
    overflow: hidden;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.96);
    padding: 26px;
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
  }

  .filter-panel::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 5px;
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-strong) 100%
    );
  }

  .filter-panel h2 {
    margin: 0 0 18px;
    color: var(--color-text);
    font-size: 24px;
    line-height: 1.35;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .filter-list {
    display: grid;
    gap: 10px;
    margin: 0 0 22px;
    padding: 0;
    list-style: none;
  }

  .filter-list li {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 999px;
    background: var(--color-accent-pale);
    color: var(--color-accent-dark);
    font-size: 13px;
    font-weight: 800;
  }

  .muted {
    margin: 0 0 22px;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.8;
  }

  .search-link,
  .empty-state-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-strong) 100%
    );
    color: #fff;
    text-decoration: none;
    font-weight: 900;
    box-shadow: 0 12px 24px rgba(231, 52, 24, 0.2);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
  }

  .search-link {
    width: 100%;
  }

  .search-link:hover,
  .empty-state-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(231, 52, 24, 0.26);
    opacity: 0.98;
  }

  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 18px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.96);
    padding: 22px 24px;
    box-shadow: 0 14px 34px rgba(46, 10, 5, 0.06);
  }

  .toolbar-eyebrow {
    margin-bottom: 6px;
  }

  .result-count {
    margin: 0;
    color: var(--color-text);
    font-size: 18px;
    font-weight: 900;
  }

  .sort-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .sort-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 14px;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 999px;
    background: #fff;
    color: var(--color-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 800;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .sort-link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-pale);
    color: var(--color-accent-dark);
    transform: translateY(-1px);
  }

  .sort-link.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 10px 20px rgba(231, 52, 24, 0.16);
  }

  .card-list {
    display: grid;
    gap: 22px;
    margin-bottom: 32px;
  }

  .card-list :global(.property-card) {
    border-color: rgba(138, 31, 15, 0.14);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
  }

  .empty-state {
    padding: 56px 24px;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.96);
    text-align: center;
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
  }

  .empty-state-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .empty-state h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.35;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .empty-state p {
    margin: 0 0 24px;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.8;
  }

  .empty-state-link {
    min-width: 180px;
    padding: 0 20px;
  }

  @media (max-width: 960px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .filter-panel {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .properties-hero {
      padding: 64px 0 52px;
    }

    .properties-content {
      padding: 48px 0 72px;
    }

    .filter-panel,
    .toolbar,
    .empty-state {
      border-radius: 22px;
    }

    .filter-panel,
    .toolbar {
      padding: 22px;
    }

    .toolbar {
      align-items: flex-start;
    }

    .sort-link {
      font-size: 13px;
    }
  }
</style>