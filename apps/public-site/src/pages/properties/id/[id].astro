---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContactCta from "../../components/layout/ContactCta.astro";

export function getStaticPaths() {
  return [
    { params: { id: "1" } },
    { params: { id: "2" } },
    { params: { id: "3" } },
  ];
}

const { id } = Astro.params;
---

<BaseLayout title={`物件詳細 ${id} | みやび共栄土地株式会社`}>
  <section class="section">
    <div class="container">
      <h1 class="section-title">物件詳細</h1>
      <p class="section-lead">物件ID: {id}</p>
      <p>ここに物件詳細を実装していきます。</p>
    </div>
  </section>
  <ContactCta />
</BaseLayout>