---
import InquiryForm from "../components/forms/InquiryForm.astro";
import PublicSiteLayout from "../layouts/PublicSiteLayout.astro";
---

<PublicSiteLayout
  title="お問い合わせ | 不動産サイト"
  description="物件に関するお問い合わせページです。見学予約、資料請求、ご相談はこちらからご確認ください。"
>
  <div class="contact-page">
    <section class="contact-hero">
      <div class="container">
        <div class="contact-hero__inner">
          <p class="contact-hero__eyebrow">CONTACT</p>
          <h1 class="contact-hero__title">お問い合わせ</h1>
          <p class="contact-hero__lead">
            物件の見学予約、資料請求、購入のご相談など、お気軽にお問い合わせください。
          </p>
        </div>
      </div>
    </section>

    <section class="contact-content">
      <div class="container contact-grid">
        <section class="contact-panel">
          <div class="contact-panel__header">
            <p class="contact-panel__eyebrow">INQUIRY FORM</p>
            <h2>お問い合わせフォーム</h2>
            <p>
              ご相談内容をご入力ください。内容を確認後、担当者より順次ご連絡いたします。
            </p>
          </div>

          <InquiryForm
            inquiryType="general"
            title="お問い合わせ"
            description="物件見学、資料請求、購入相談、エリア相談などお気軽にご連絡ください。"
            submitLabel="送信する"
          />
        </section>

        <aside class="contact-side-card">
          <p class="contact-side-card__eyebrow">GUIDE</p>
          <h2>ご相談について</h2>

          <div class="contact-info-list">
            <div>
              <h3>対応内容</h3>
              <p>物件見学、資料請求、購入相談、エリア相談などに対応しています。</p>
            </div>

            <div>
              <h3>対応時間</h3>
              <p>営業時間内に内容を確認し、担当者より順次ご案内いたします。</p>
            </div>

            <div>
              <h3>補足</h3>
              <p>
                具体的な希望条件がある場合は、検索ページや物件一覧もあわせてご確認ください。
              </p>
            </div>
          </div>

          <div class="contact-actions">
            <a href="/search" class="primary-button">条件から探す</a>
            <a href="/properties" class="secondary-button">物件一覧を見る</a>
          </div>
        </aside>
      </div>
    </section>
  </div>
</PublicSiteLayout>

<style>
  .contact-page {
    background: #ffffff;
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    padding: 84px 0 72px;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.9) 0%,
        rgba(255, 255, 255, 0.72) 48%,
        rgba(255, 255, 255, 0.38) 100%
      ),
      url("/images/sections/hero-bg.jpg");
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(138, 31, 15, 0.12);
  }

  .contact-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(46, 10, 5, 0.05);
    pointer-events: none;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .contact-hero__eyebrow,
  .contact-panel__eyebrow,
  .contact-side-card__eyebrow {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .contact-hero__title {
    margin: 0 0 16px;
    color: var(--color-text);
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .contact-hero__lead {
    margin: 0;
    max-width: 680px;
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.9;
  }

  .contact-content {
    padding: 72px 0 96px;
    background: #ffffff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 28px;
    align-items: start;
  }

  .contact-panel,
  .contact-side-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(138, 31, 15, 0.14);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 42px rgba(46, 10, 5, 0.08);
  }

  .contact-panel {
    padding: 36px;
  }

  .contact-side-card {
    padding: 30px;
  }

  .contact-panel::before,
  .contact-side-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 5px;
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-strong) 100%
    );
  }

  .contact-panel__header {
    margin-bottom: 30px;
  }

  .contact-panel__header h2,
  .contact-side-card h2 {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.3;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .contact-panel__header p {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    line-height: 1.8;
  }

  .contact-info-list {
    display: grid;
    gap: 22px;
    margin-top: 24px;
  }

  .contact-info-list h3 {
    margin: 0 0 8px;
    color: var(--color-text);
    font-size: 18px;
    line-height: 1.5;
    font-weight: 900;
  }

  .contact-info-list h3::before {
    content: "";
    display: inline-block;
    width: 8px;
    height: 8px;
    margin-right: 8px;
    border-radius: 999px;
    background: var(--color-accent);
    vertical-align: middle;
  }

  .contact-info-list p {
    margin: 0;
    color: var(--color-muted);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.9;
  }

  .contact-actions {
    display: grid;
    gap: 12px;
    margin-top: 28px;
  }

  @media (max-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-hero {
      padding: 64px 0 52px;
    }

    .contact-content {
      padding: 48px 0 72px;
    }

    .contact-panel,
    .contact-side-card {
      border-radius: 22px;
    }

    .contact-panel {
      padding: 28px 22px;
    }

    .contact-side-card {
      padding: 26px 22px;
    }
  }
</style>